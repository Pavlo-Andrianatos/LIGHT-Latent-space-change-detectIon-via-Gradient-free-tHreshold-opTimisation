[EXPERIMENTTHRESHOLD] # Note, the values below are updated in ExperimentGatheringScript_Actual.py during runtime
optimisation_algorithm = # Input algorithm used (pso, cma, ga, pyHopper)
number_of_epochs = # Number of training iterations
learning_rate = # Not used, artifact from prior development
training_ratio = # Ratio of training to validation set. Example: 0.8, means 0.8 would go to training set, rest to validation set
fitness_function = # Always score. But can tell optimisers to fit to precision or another metric
path_to_models = # Path to model directory
loaded_model_name = # Name of model to use for threshold optimisation
csv_file_to_use = # Path to .csv file to use for training and validation sets
csv_file_to_use_test = # Path to .csv file to use for test set
path_to_usable_images = # Path to images to use for optimising
output_images = # True or False. If it should output images
output_every_x_images = # Every image then set 1 else set to 2 for every second or 3 for every third image etc.
number_of_classes = # Number of classes for dataset
image_channels = # Image channels, RGB would be 3. Not used
dataset_used = # Dataset to use (vaihingen, french, syn)
number_of_change_images = # Number of images to use to optimise thresholds (5, 10, 15, 20). And any number above or below

